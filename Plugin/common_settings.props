<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(SolutionDir)user_settings.props" Condition="Exists('$(SolutionDir)user_settings.props')" />
  <!-- Common settings for all project files in this mod. The settings can be modified or expanded
       for your development environment by using the "user_settings.props" file.

       ** DO NOT EDIT THIS FILE ** unless you are maintaining the build system of the mod for all users

       -->

  <PropertyGroup>
    <!-- MOD_DIR specifies the root directory of the mod. It should not need to be modified. -->
    <MOD_DIR>$(SolutionDir)../</MOD_DIR>

    <!-- KSP_DIR specifies the KSP directory used for DLL References and also where the output files are copied.
         It can be overridden either in the .user file or via an environment variable. -->
    <KSP_DIR Condition="'$(KSP_DIR)'==''">$(MOD_DIR)../KSP_Dev/</KSP_DIR>

    <!-- KSP_DLL_DIR is a platform-specific location where the KSP DLLs are found. It should not need to be modified. -->
    <KSP_DLL_DIR Condition="'$(OS)'=='Windows_NT'">$(KSP_DIR)KSP_x64_Data/Managed/</KSP_DLL_DIR>
    <KSP_DLL_DIR Condition="'$(OS)'!='Windows_NT'">$(KSP_DIR)KSP_Data/Managed/</KSP_DLL_DIR>

    <!-- KSP_BIN is the platform-specific name of the KSP binary. It should not need to be modified. -->
    <KSP_BIN Condition="'$(OS)'=='Windows_NT'">$(KSP_DIR)KSP_x64.exe</KSP_BIN>
    <KSP_BIN Condition="'$(OS)'!='Windows_NT'">$(KSP_DIR)KSP.x86_64</KSP_BIN>
  </PropertyGroup>

  <!-- The following references all KSP related DLL's -->
  <ItemGroup>
    <Reference Include="$(KSP_DLL_DIR)Assembly*.dll">
      <Private>False</Private>
    </Reference>
    <Reference Include="$(KSP_DLL_DIR)Unity*.dll">
      <Private>False</Private>
    </Reference>
  </ItemGroup>
</Project>
