  <!-- Generate the version file from the compiled binary -->
  <Target Name="GetAssemblyVersion" AfterTargets="Build" BeforeTargets="AfterBuild">
    <GetAssemblyIdentity AssemblyFiles="$(TargetPath)">
      <Output TaskParameter="Assemblies" ItemName="Targets" />
    </GetAssemblyIdentity>
    <Message Text="Assembly Version: %(Targets.Version)" Importance="high" />
    <WriteLinesToFile File="$(SolutionDir)/version.txt" Overwrite="true" Lines="%(Targets.Version)" />
    <ItemGroup>
      <VersionNumber Include="@(Targets->'%(Version)')" />
    </ItemGroup>
  </Target>
  <!-- Target to copy the compiled binary into the Mod's GameData directory -->
  <Target Name="CopyToDistDir" AfterTargets="Build">
    <ItemGroup>
      <PluginFiles Include="$(TargetPath)" />
      <PluginFiles Include="$(TargetDir)$(TargetName).pdb" Condition=" '$(Configuration)' == 'Debug' " />
    </ItemGroup>
    <Copy SourceFiles="@(PluginFiles)"
          DestinationFolder="$(MOD_DIR)GameData/NehemiahInc/NE_Science_Common/Plugins/"
          SkipUnchangedFiles="true"
          OverwriteReadOnlyFiles="true"
          Retries="3"
          RetryDelayMilliseconds="300" />
  </Target>
  <!-- Target to copy all files to KSP's GameData directory -->
  <Target Name="CopyToKspDir" AfterTargets="CopyToDistDir" Condition="Exists('$(KSP_DIR)GameData/NehemiahInc')">
    <ItemGroup>
      <GameDataFiles Include="$(MOD_DIR)GameData/NehemiahInc/**/*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(GameDataFiles)"
          DestinationFolder="$(KSP_DIR)GameData/NehemiahInc/%(RecursiveDir)"
          SkipUnchangedFiles="true"
          OverwriteReadOnlyFiles="true"
          Retries="3"
          RetryDelayMilliseconds="300" />
  </Target>
  <!-- Target to start KSP from within an IDE -->
  <PropertyGroup>
    <StartAction>Program</StartAction>
    <StartProgram>$(KSP_DIR)$(KSP_BIN)</StartProgram>
    <StartWorkingDirectory>$(KSP_DIR)</StartWorkingDirectory>
  </PropertyGroup>
